ly, so this container won’t present or dismiss toasts synchronously during","type":"text"},{"text":" ","type":"text"},{"text":"the screen update of a workflow render.","type":"text"}]}]}],"abstract":[{"text":"Use a ","type":"text"},{"code":"ToastContainer","type":"codeVoice"},{"text":" to render a base screen and an array of toasts on top of it.","type":"text"}],"references":{"doc://WorkflowModals/documentation/WorkflowModals/ToastContainer/init(base:toasts:)-7i3rw":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"base"},{"kind":"text","text":": () -> "},{"preciseIdentifier":"s:14WorkflowModals14ToastContainerV11BaseContentxmfp","kind":"typeIdentifier","text":"BaseContent"},{"kind":"text","text":", "},{"kind":"externalParam","text":"toasts"},{"kind":"text","text":": () -> ["},{"preciseIdentifier":"s:14WorkflowModals5ToastV","kind":"typeIdentifier","text":"Toast"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:14WorkflowModals14ToastContainerV0C7Contentq_mfp","kind":"typeIdentifier","text":"ToastContent"},{"kind":"text","text":">])"}],"role":"symbol","title":"init(base:toasts:)","url":"\/documentation\/workflowmodals\/toastcontainer\/init(base:toasts:)-7i3rw","type":"topic","identifier":"doc:\/\/WorkflowModals\/documentation\/WorkflowModals\/ToastContainer\/init(base:toasts:)-7i3rw","kind":"symbol","abstract":[{"type":"text","text":"Create a toast container with a base screen and array of toasts."}]},"x-source-tag://ModalHostContainer":{"titleInlineContent":[{"type":"text","text":"ModalHostContainer"}],"url":"x-source-tag:\/\/ModalHostContainer","type":"link","identifier":"x-source-tag:\/\/ModalHostContainer","title":"ModalHostContainer"},"doc://WorkflowModals/documentation/WorkflowModals":{"title":"WorkflowModals","url":"\/documentation\/workflowmodals","kind":"symbol","role":"collection","identifier":"doc:\/\/WorkflowModals\/documentation\/WorkflowModals","type":"topic","abstract":[]},"x-source-tag://M