{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@objc","kind":"attribute"},{"text":"(mdl_aggregateModals) ","kind":"text"},{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"aggregateModals","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"c:@M@Modals@objc(cs)MDLModalList","text":"ModalList","kind":"typeIdentifier","identifier":"doc:\/\/Modals\/documentation\/Modals\/ModalList"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modal presentation system aggregates presented modals by calling this method. The"},{"type":"text","text":" "},{"type":"text","text":"default implementation retrieves this value from each of its child view controllers, and"},{"type":"text","text":" "},{"type":"text","text":"then appends any modals presented from this view controller’s "},{"type":"codeVoice","code":"ModalPresenter"},{"type":"text","text":", performing a"},{"type":"text","text":" "},{"type":"text","text":"depth-first traversal of the view controller hierarchy."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can override this method to change which modals are propagated up this hierarchy. For"},{"type":"text","text":" "},{"type":"text","text":"example, you can prevent some modals from being aggregated to the root depending on whether"},{"type":"text","text":" "},{"type":"text","text":"this view controller is currently visible. When overriding this method, you may find "},{"code":"aggregateChildModals","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"aggregatePresenterModals","type":"codeVoice"},{"type":"text","text":", and "},{"code":"aggregateModalListAggregationModals","type":"codeVoice"},{"type":"text","text":" useful."}]}]}],"sections":[],"identifier":{"url":"doc:\/\/Modals\/documentation\/Modals\/UIKit\/UIViewController\/aggregateModals()","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"c:@CM@Modals@@objc(cs)UIViewController(im)mdl_aggregateModals","role":"symbol","modules":[{"name":"Modals","relatedModules":["UIKit"]}],"roleHeading":"Instance Method","title":"aggregateModals()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"aggregateModals","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"c:@M@Modals@objc(cs)MDLModalList","text":"ModalList","kind":"typeIdentifier"}],"extendedModule":"UIKit","symbolKind":"method"},"abstract":[{"text":"Returns the presented modals associated with this view controller and its descendants.","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/modals\/uikit\/uiviewcontroller\/aggregatemodals()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Modals\/documentation\/Modals","doc:\/\/Modals\/documentation\/Modals\/UIKit","doc:\/\/Modals\/documentation\/Modals\/UIKit\/UIViewController"]]},"references":{"doc://Modals/documentation/Modals":{"identifier":"doc:\/\/Modals\/documentation\/Modals","type":"topic","title":"Modals","url":"\/documentation\/modals","kind":"symbol","role":"collection","abstract":[]},"doc://Modals/documentation/Modals/UIKit":{"type":"topic","abstract":[],"url":"\/documentation\/modals\/uikit","identifier":"doc:\/\/Modals\/documentation\/Modals\/UIKit","kind":"symbol","title":"UIKit","role":"collection"},"doc://Modals/documentation/Modals/UIKit/UIViewController/aggregateModals()":{"url":"\/documentation\/modals\/uikit\/uiviewcontroller\/aggregatemodals()","type":"topic","title":"aggregateModals()","identifier":"doc:\/\/Modals\/documentation\/Modals\/UIKit\/UIViewController\/aggregateModals()","fragments":[{"kind":"k